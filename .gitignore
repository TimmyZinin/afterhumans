# Unity generated (standard .gitignore from Unity template)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Unity Asset meta data may be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/ExportedObj/
/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
unity-project/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
unity-project/[Aa]ssets/[Ss]treamingAssets/aa.meta
unity-project/[Aa]ssets/[Ss]treamingAssets/aa/*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Large binary build artifacts (use Git LFS or external hosting)
*.dmg
*.zip
*.tar.gz

# Downloaded asset archives (too big for git)
Assets/Vendor/downloads/

# External vendor assets (each developer downloads via scripts/download-assets.sh)
Assets/_Project/Vendor/Kenney/
Assets/_Project/Vendor/PolyHaven/
Assets/_Project/Vendor/Mixamo/
Assets/_Project/Vendor/Sketchfab/
Assets/_Project/Vendor/Quaternius/
Assets/_Project/Vendor/Megascans/

# Env / secrets
.env
.env.local
*.key
*.pem

# Stylized Nature MegaKit (Quaternius, CC0) — vendored locally, regen via scripts/download-assets.sh or from Downloads zip
/Assets/ThirdParty/StylizedNature/
