# Unity generated
unity-project/[Ll]ibrary/
unity-project/[Tt]emp/
unity-project/[Oo]bj/
unity-project/[Bb]uild/
unity-project/[Bb]uilds/
unity-project/[Ll]ogs/
unity-project/[Uu]ser[Ss]ettings/
unity-project/[Mm]emoryCaptures/
unity-project/[Rr]ecordings/

# Unity Asset meta data may be ignored when the corresponding asset is also ignored
!unity-project/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# unity-project/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
unity-project/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
unity-project/ExportedObj/
unity-project/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
unity-project/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
unity-project/[Aa]ssets/[Ss]treamingAssets/aa.meta
unity-project/[Aa]ssets/[Ss]treamingAssets/aa/*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Large binary build artifacts (use Git LFS or external hosting)
*.dmg
*.zip
*.tar.gz

# Downloaded asset archives (too big for git)
Assets/Vendor/downloads/

# Env / secrets
.env
.env.local
*.key
*.pem
